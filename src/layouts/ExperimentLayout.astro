---
import '../styles/global.css';

interface Props {
  title: string;
  number: string;
  description: string;
  tags: string[];
  githubPath: string;
}

const { title, number, description, tags, githubPath } = Astro.props;
const githubBase = 'https://github.com/alessandrosestili/ui-playground/blob/main/src/pages/experiments/';
---

<!doctype html>
<html lang="en" class="noise">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{number} — {title} | UI Playground</title>
  </head>
  <body>
    <!-- Back nav -->
    <nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 py-4"
         style="background: rgba(5, 5, 16, 0.8); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,0.05);">
      <a href="/" class="flex items-center gap-3 group">
        <span class="text-slate-400 group-hover:text-white transition-colors duration-200 text-sm">←</span>
        <span class="font-mono text-xs text-slate-500 group-hover:text-slate-300 transition-colors duration-200 uppercase tracking-widest">UI Playground</span>
      </a>

      <div class="flex items-center gap-4">
        <div class="flex gap-2">
          {tags.map(tag => (
            <span class="font-mono text-xs px-2 py-1 rounded"
                  style="background: rgba(124,58,237,0.1); color: #a78bfa; border: 1px solid rgba(124,58,237,0.2);">
              {tag}
            </span>
          ))}
        </div>
        <a
          href={githubBase + githubPath}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 font-mono text-xs px-3 py-1.5 rounded transition-all duration-200"
          style="background: rgba(6,182,212,0.1); color: #22d3ee; border: 1px solid rgba(6,182,212,0.2);"
          onmouseover="this.style.background='rgba(6,182,212,0.2)'"
          onmouseout="this.style.background='rgba(6,182,212,0.1)'"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          View Source
        </a>
      </div>
    </nav>

    <!-- Experiment header -->
    <header class="pt-24 pb-8 px-6 max-w-4xl mx-auto">
      <p class="font-mono text-xs mb-3" style="color: var(--violet);">EXPERIMENT {number}</p>
      <h1 class="text-4xl font-bold text-white mb-3">{title}</h1>
      <p class="text-slate-400 text-lg">{description}</p>
    </header>

    <main class="px-6 pb-16 max-w-4xl mx-auto">
      <slot />
    </main>
  </body>
</html>
