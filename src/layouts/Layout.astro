---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Interactive front end experiments by Alessandro Sestili' } = Astro.props;
---

<!doctype html>
<html lang="en" class="noise">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | UI Playground</title>
  </head>
  <body>
    <a
      href="https://portfolio-alessandrosestili.vercel.app"
      class="fixed top-4 left-4 z-50 flex items-center gap-2 group px-3 py-2 rounded-lg transition-all duration-200"
      style="background: rgba(124,58,237,0.08); border: 1px solid rgba(124,58,237,0.2);"
      onmouseover="this.style.background='rgba(124,58,237,0.18)'"
      onmouseout="this.style.background='rgba(124,58,237,0.08)'"
      title="Back to Portfolio"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#a78bfa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 12L12 3l9 9"/><path d="M9 21V12h6v9"/>
      </svg>
      <span class="font-mono text-xs" style="color: #a78bfa;">Portfolio</span>
    </a>
    <slot />
  </body>
</html>
