---
import Layout from '../layouts/Layout.astro';

const experiments = [
  {
    number: '01',
    slug: 'magnetic-cursor',
    title: 'Magnetic Cursor',
    description: 'Custom cursor that magnetically attracts interactive elements on hover — gravity-defying UX.',
    tags: ['React', 'CSS Props', 'mousemove'],
    color: 'violet',
  },
  {
    number: '02',
    slug: 'scroll-reveal',
    title: 'Scroll Reveal',
    description: 'Text and elements that enter the scene with cinematic timing as you scroll.',
    tags: ['Framer Motion', 'Intersection Observer'],
    color: 'cyan',
  },
  {
    number: '03',
    slug: 'page-transition',
    title: 'Page Transition',
    description: 'Neon mask that covers and uncovers the screen during navigation. Fluid, dramatic.',
    tags: ['Framer Motion', 'View Transitions'],
    color: 'amber',
  },
  {
    number: '04',
    slug: 'interactive-form',
    title: 'Interactive Form',
    description: 'Contact form where every field has its own personality — floating labels, animated borders, loading states.',
    tags: ['React', 'CSS Animations', 'Form States'],
    color: 'violet',
  },
  {
    number: '05',
    slug: '3d-scene',
    title: '3D Scene',
    description: 'Three.js geometry that rotates and follows your cursor in 3D space. Immersive.',
    tags: ['Three.js', 'React Three Fiber', 'mousemove'],
    color: 'cyan',
  },
  {
    number: '06',
    slug: 'css-magic',
    title: 'CSS Magic',
    description: 'Complex visual effect built entirely in pure CSS. Zero JavaScript. Deep mastery.',
    tags: ['CSS Animations', 'Keyframes', 'Custom Props'],
    color: 'amber',
  },
];

const colorMap = {
  violet: { accent: '#7C3AED', glow: 'rgba(124,58,237,0.15)', border: 'rgba(124,58,237,0.25)', text: '#a78bfa' },
  cyan:   { accent: '#06B6D4', glow: 'rgba(6,182,212,0.15)',  border: 'rgba(6,182,212,0.25)',  text: '#22d3ee' },
  amber:  { accent: '#F59E0B', glow: 'rgba(245,158,11,0.15)', border: 'rgba(245,158,11,0.25)', text: '#fbbf24' },
};
---

<Layout title="UI Playground">
  <!-- Ambient background -->
  <div class="fixed inset-0 pointer-events-none" style="z-index: 0;">
    <div style="position:absolute; top:-20%; left:-10%; width:600px; height:600px; background:radial-gradient(circle, rgba(124,58,237,0.08) 0%, transparent 70%); border-radius:50%;"></div>
    <div style="position:absolute; bottom:-20%; right:-10%; width:700px; height:700px; background:radial-gradient(circle, rgba(6,182,212,0.06) 0%, transparent 70%); border-radius:50%;"></div>
  </div>

  <div class="relative" style="z-index: 1;">
    <!-- Nav -->
    <nav class="flex items-center justify-between px-8 py-6 max-w-7xl mx-auto">
      <span class="font-mono text-xs text-slate-600 tracking-widest uppercase">Alessandro Sestili</span>
      <a
        href="https://github.com/AlessandroSestili/ui-playground"
        target="_blank"
        rel="noopener noreferrer"
        class="font-mono text-xs text-slate-500 hover:text-slate-300 transition-colors duration-200 flex items-center gap-2"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        GitHub
      </a>
    </nav>

    <!-- Hero -->
    <header class="px-8 pt-16 pb-24 max-w-7xl mx-auto">
      <div class="mb-6">
        <span class="font-mono text-xs tracking-widest uppercase px-3 py-1.5 rounded-full"
              style="background: rgba(124,58,237,0.1); color: #a78bfa; border: 1px solid rgba(124,58,237,0.2);">
          v1.0 — 6 experiments
        </span>
      </div>

      <h1 class="text-7xl font-bold leading-none mb-6" style="letter-spacing: -0.03em;">
        <span class="text-white">UI </span>
        <span style="background: linear-gradient(135deg, #7C3AED 0%, #06B6D4 50%, #F59E0B 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; background-size: 200% 200%; animation: gradient-shift 4s ease infinite;">Playground</span>
      </h1>

      <p class="text-xl text-slate-400 max-w-xl leading-relaxed">
        A collection of interactive front end experiments.<br />
        <span class="text-slate-500">Each one pushing the limits of what's possible in the browser.</span>
      </p>

      <!-- Stats row -->
      <div class="flex gap-8 mt-12">
        {[
          { label: 'Experiments', value: '06' },
          { label: 'Technologies', value: '12+' },
          { label: 'Lines of code', value: '~2k' },
        ].map(stat => (
          <div>
            <div class="text-3xl font-bold font-mono" style="color: var(--violet);">{stat.value}</div>
            <div class="text-xs text-slate-600 uppercase tracking-widest mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
    </header>

    <!-- Grid -->
    <section class="px-8 pb-24 max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {experiments.map((exp) => {
          const c = colorMap[exp.color as keyof typeof colorMap];
          return (
            <a
              href={`/experiments/${exp.slug}`}
              class="group relative flex flex-col p-6 rounded-2xl transition-all duration-300"
              style={`background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); text-decoration: none;`}
            >
              <!-- Hover glow bg -->
              <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"
                   style={`background: ${c.glow}; border: 1px solid ${c.border};`}></div>

              <div class="relative">
                <!-- Number -->
                <div class="flex items-center justify-between mb-5">
                  <span class="font-mono text-xs font-bold tracking-widest" style={`color: ${c.text};`}>
                    {exp.number}
                  </span>
                  <span class="text-slate-700 group-hover:text-slate-400 transition-colors duration-300 text-lg">→</span>
                </div>

                <!-- Title -->
                <h2 class="text-xl font-semibold text-white mb-3 group-hover:text-white transition-colors duration-200">
                  {exp.title}
                </h2>

                <!-- Description -->
                <p class="text-sm text-slate-500 leading-relaxed mb-6 group-hover:text-slate-400 transition-colors duration-200">
                  {exp.description}
                </p>

                <!-- Tags -->
                <div class="flex flex-wrap gap-2 mt-auto">
                  {exp.tags.map(tag => (
                    <span class="font-mono text-xs px-2 py-1 rounded"
                          style={`background: rgba(255,255,255,0.03); color: ${c.text}; border: 1px solid rgba(255,255,255,0.06); opacity: 0.8;`}>
                      {tag}
                    </span>
                  ))}
                </div>

                <!-- View link -->
                <div class="mt-5 pt-5 border-t border-white/5">
                  <span class="font-mono text-xs tracking-wide transition-all duration-200 flex items-center gap-2"
                        style={`color: ${c.text};`}>
                    View experiment
                    <span class="group-hover:translate-x-1 transition-transform duration-200 inline-block">→</span>
                  </span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <!-- Footer -->
    <footer class="px-8 py-8 border-t border-white/5 max-w-7xl mx-auto flex items-center justify-between">
      <span class="font-mono text-xs text-slate-700">Built with Astro + React + Tailwind</span>
      <span class="font-mono text-xs text-slate-700">Alessandro Sestili © 2025</span>
    </footer>
  </div>
</Layout>
